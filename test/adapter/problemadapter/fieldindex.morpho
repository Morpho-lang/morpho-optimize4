// ProblemAdapter test: CG(2) and CG(3) fields on line elements and edge-DOF gradients
//
// CG2: FiniteElementSpace("CG2", grade=1), shape [1, 1] (one DOF per vertex and edge)
// CG3: FiniteElementSpace("CG3", grade=1), shape [1, 2] (one vertex DOF, two edge DOFs)
// LineIntegral passes method={} for the element-local quadrature / fieldgradient path.

import optimize4
import meshtools

class CG2FieldExample {
  init(edgeTarget=0.25) {
    self.edgeTarget = edgeTarget
    self.mesh = LineMesh(fn (u) [cos(u), sin(u)], -Pi...Pi:Pi/6, closed=false)
    self.mesh.addgrade(1)
    self.mesh = ChangeMeshDimension(self.mesh, 3)

    var fs = FiniteElementSpace("CG2", grade=1)
    self.field = Field(self.mesh, Matrix([0.5, 0.2, 0.0]), finiteelementspace=fs)

    self.problem = OptimizationProblem(self.mesh)
    self.problem.addenergy(NormSq(self.field))

    var edgeFunc = LineIntegral(fn (x, fv) fv[0]^2, self.field, method={})
    self.problem.addlocalconstraint(edgeFunc, target=self.edgeTarget)

    self.adapter = ProblemAdapter(self.problem, self.field)
  }
}

var ex = CG2FieldExample()
var adapt = ex.adapter
var mesh = ex.mesh
var field = ex.field
var fs = field.finiteElementSpace()

print adapt.count(field)
// expect: 69

print field.shape()
// expect: [ 1, 1 ]

print fs.grade()
// expect: 1

// selectionToIndexList: edges 0 and 5 -> six linear indices
var sel = Selection(mesh)
sel.addgrade(1)
sel[1, 0] = true
sel[1, 5] = true
var fixix = adapt.selectionToIndexList(sel, field)
print fixix.count()
// expect: 6

print fixix[0]
// expect: 36

print fixix[3]
// expect: 51

var eps = 1e-6
var x0 = adapt.get()
var c0 = adapt.constraintValue()
var cg = adapt.constraintGradient()

// Edge 3, component 1: pool index 15, linear index 15*3+1 = 46
var lin = adapt._fieldLinearIndex(field, 1, 3, 0, 1)
print lin
// expect: 46

adapt.set(x0)
var x1 = x0.clone()
x1[lin] += eps
adapt.set(x1)
var c1 = adapt.constraintValue()
var fd = (c1[0][3] - c0[0][3]) / eps
var ana = cg[0][lin, 3]

print abs(fd - ana) < 1e-4
// expect: true

adapt.set(x0)

// ---------------------------------------------------------------------------
// CG(3) on line elements: shape [1, 2] (two DOFs per edge)

class CG3FieldExample {
  init(edgeTarget=0.25) {
    self.mesh = LineMesh(fn (u) [cos(u), sin(u)], -Pi...Pi:Pi/6, closed=false)
    self.mesh.addgrade(1)
    self.mesh = ChangeMeshDimension(self.mesh, 3)

    var fs = FiniteElementSpace("CG3", grade=1)
    self.field = Field(self.mesh, Matrix([0.5, 0.2, 0.0]), finiteelementspace=fs)

    self.problem = OptimizationProblem(self.mesh)
    self.problem.addenergy(NormSq(self.field))

    var edgeFunc = LineIntegral(fn (x, fv) fv[0]^2, self.field, method={})
    self.problem.addlocalconstraint(edgeFunc, target=edgeTarget)

    self.adapter = ProblemAdapter(self.problem, self.field)
  }
}

var ex3 = CG3FieldExample()
var adapt3 = ex3.adapter
var mesh3 = ex3.mesh
var field3 = ex3.field

print adapt3.count(field3)
// expect: 102

print field3.shape()
// expect: [ 1, 2 ]

// One edge, two DOFs per edge, three prototype components -> six indices
var sel3 = Selection(mesh3)
sel3.addgrade(1)
sel3[1, 0] = true
var fixix3 = adapt3.selectionToIndexList(sel3, field3)
print fixix3.count()
// expect: 6

print fixix3[0]
// expect: 36

print fixix3[3]
// expect: 39

x0 = adapt3.get()
c0 = adapt3.constraintValue()
cg = adapt3.constraintGradient()

// Edge 3, DOF index 1, component 0: pool 19, linear 57
lin = adapt3._fieldLinearIndex(field3, 1, 3, 1, 0)
print lin
// expect: 57

adapt3.set(x0)
x1 = x0.clone()
x1[lin] += eps
adapt3.set(x1)
c1 = adapt3.constraintValue()
fd = (c1[0][3] - c0[0][3]) / eps
ana = cg[0][lin, 3]

print abs(fd - ana) < 1e-4
// expect: true

adapt3.set(x0)
