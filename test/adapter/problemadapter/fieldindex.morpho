// ProblemAdapter test: CG(2) and CG(3) field indexing on line elements
//
// Checks DOF counts, selectionToIndexList, and _fieldLinearIndex mapping.
// Gradient FD checks are in fieldindex_gradient.morpho.

import optimize4
import meshtools

class CG2FieldExample {
  init() {
    self.mesh = LineMesh(fn (u) [cos(u), sin(u)], -Pi...Pi:Pi/6, closed=false)
    self.mesh.addgrade(1)
    self.mesh = ChangeMeshDimension(self.mesh, 3)

    var fs = FiniteElementSpace("CG2", grade=1)
    self.field = Field(self.mesh, Matrix([0.5, 0.2, 0.0]), finiteelementspace=fs)

    self.problem = OptimizationProblem(self.mesh)
    var energy = LineIntegral(fn (x, fv) fv[0]^2, self.field, method={})
    self.problem.addEnergy(energy)

    self.adapter = ProblemAdapter(self.problem, self.field)
  }
}

var ex = CG2FieldExample()
var adapt = ex.adapter
var mesh = ex.mesh
var field = ex.field

print adapt.count(field)
// expect: 69

print field.shape()
// expect: [ 1, 1 ]

var sel = Selection(mesh)
sel.addgrade(1)
sel[1, 0] = true
sel[1, 5] = true
var fixix = adapt.selectionToIndexList(sel, field)
print fixix.count()
// expect: 6

print fixix[0]
// expect: 36

print fixix[3]
// expect: 51

var lin = adapt._fieldLinearIndex(field, 1, 3, 0, 1)
print lin
// expect: 46

class CG3FieldExample {
  init() {
    self.mesh = LineMesh(fn (u) [cos(u), sin(u)], -Pi...Pi:Pi/6, closed=false)
    self.mesh.addgrade(1)
    self.mesh = ChangeMeshDimension(self.mesh, 3)

    var fs = FiniteElementSpace("CG3", grade=1)
    self.field = Field(self.mesh, Matrix([0.5, 0.2, 0.0]), finiteelementspace=fs)

    self.problem = OptimizationProblem(self.mesh)
    var energy = LineIntegral(fn (x, fv) fv[0]^2, self.field, method={})
    self.problem.addEnergy(energy)

    self.adapter = ProblemAdapter(self.problem, self.field)
  }
}

var ex3 = CG3FieldExample()
var adapt3 = ex3.adapter
var mesh3 = ex3.mesh
var field3 = ex3.field

print adapt3.count(field3)
// expect: 102

print field3.shape()
// expect: [ 1, 2 ]

var sel3 = Selection(mesh3)
sel3.addgrade(1)
sel3[1, 0] = true
var fixix3 = adapt3.selectionToIndexList(sel3, field3)
print fixix3.count()
// expect: 6

print fixix3[0]
// expect: 36

print fixix3[3]
// expect: 39

lin = adapt3._fieldLinearIndex(field3, 1, 3, 1, 0)
print lin
// expect: 57
