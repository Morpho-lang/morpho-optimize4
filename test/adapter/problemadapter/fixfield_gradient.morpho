// [CI:Smoke]
// FixAdapter gradient checks: zero at fixed DOFs, nonzero in the interior.
// Kept separate from fixfield.morpho: gradient checks can flake under morpho6 -w4/-w8.

import optimize4
import meshtools
import "gradienthelpers.morpho" for GradZeroTol, GradNonzeroTol

var m = LineMesh(fn (u) [u, 0, 0], 0..1:0.25, closed=false)
m.addgrade(1)

var fs = FiniteElementSpace("CG2", grade=1)
var f = Field(m, Matrix([0.0]), finiteelementspace=fs)

var uLeft = 1.0
var uRight = 0.0
f[0, 0] = Matrix([uLeft])
f[0, m.count(0)-1] = Matrix([uRight])

var energy = LineIntegral(fn (x, fv) fv[0]^2, f, method={})
var problem = OptimizationProblem(m)
problem.addEnergy(energy)

var padapt = ProblemAdapter(problem, f)

var bnd = Selection(m)
bnd[0, 0] = true
bnd[0, m.count(0)-1] = true
var fixix = padapt.selectionToIndexList(bnd, f)
var adapt = FixAdapter(padapt, fixix)

var x0 = adapt.get()
var g = adapt.gradient()

if (abs(g[0]) >= GradZeroTol) {
  Error("TstFixFldGrd", "Gradient should be zero at left fixed DOF").throw()
}

if (abs(g[4]) >= GradZeroTol) {
  Error("TstFixFldGrd", "Gradient should be zero at right fixed DOF").throw()
}

if (abs(g[2]) <= GradNonzeroTol) {
  Error("TstFixFldGrd", "Gradient should be nonzero at interior DOF").throw()
}

adapt.set(x0)
