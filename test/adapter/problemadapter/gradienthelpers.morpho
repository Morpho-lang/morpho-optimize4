// [CI:Ignore]
// Shared tolerances and helpers for ProblemAdapter gradient smoke tests.

var GradFdTol = 1e-5
var GradZeroTol = 1e-7
var GradNonzeroTol = 1e-8

fn _constraintScalar(Matrix cv, Int row) {
  // Local constraint values are usually (nel, 1); occasionally (1, nel).
  var dims = cv.dimensions()
  if (dims[1] == 1) return cv[row, 0]
  return cv[0, row]
}

fn fdConstraintGradientCheck(adapt, lin, row, x0, cg, eps=1e-5) {
  var x1 = x0.clone()
  x1[lin] = x0[lin] + eps
  adapt.set(x1)
  var cp = _constraintScalar(adapt.constraintValue()[0], row)

  x1[lin] = x0[lin] - eps
  adapt.set(x1)
  var cm = _constraintScalar(adapt.constraintValue()[0], row)

  adapt.set(x0)
  var fd = (cp - cm) / (2*eps)
  var ana = cg[0][lin, row]
  return abs(fd - ana) < GradFdTol
}

fn fdEnergyGradientCheck(adapt, lin, x0, g, eps=1e-5) {
  var x1 = x0.clone()
  x1[lin] = x0[lin] + eps
  adapt.set(x1)
  var vp = adapt.value()
  x1[lin] = x0[lin] - eps
  adapt.set(x1)
  var vm = adapt.value()
  adapt.set(x0)
  var fd = (vp - vm) / (2*eps)
  return abs(g[lin] - fd) < GradFdTol
}

fn fdLocalConstraintGradientCheck(adapt, consIndex, lin, row, x0, cg, eps=1e-5) {
  var x1 = x0.clone()
  x1[lin] = x0[lin] + eps
  adapt.set(x1)
  var cp = _constraintScalar(adapt.constraintValue()[consIndex], row)

  x1[lin] = x0[lin] - eps
  adapt.set(x1)
  var cm = _constraintScalar(adapt.constraintValue()[consIndex], row)

  adapt.set(x0)
  var fd = (cp - cm) / (2*eps)
  var ana = cg[consIndex][lin, row]
  return abs(fd - ana) < GradFdTol
}

fn _expect(name, cond) {
  if (!cond) Error("FldLayout", name).throw()
}
