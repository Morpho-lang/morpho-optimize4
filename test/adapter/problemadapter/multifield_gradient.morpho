// [CI:Smoke]
// FD energy gradient and constraint cross-block checks for two-field ProblemAdapter.

import optimize4
import meshtools
import "gradienthelpers.morpho" for GradZeroTol, GradNonzeroTol, fdEnergyGradientCheck

var m = LineMesh(fn (u) [u, 0, 0], 0..1:0.25, closed=false)
m.addgrade(1)

var fs = FiniteElementSpace("CG2", grade=1)
var f1 = Field(m, Matrix([1.0]), finiteelementspace=fs)
var f2 = Field(m, Matrix([2.0]), finiteelementspace=fs)

var joint = LineIntegral(fn (x, a, b) a[0]^2 + b[0]^2, f1, f2, method={})
var problem = OptimizationProblem(m)
problem.addEnergy(joint)

var edgeOnF1 = LineIntegral(fn (x, fv) fv[0]^2, f1, method={})
problem.addLocalConstraint(edgeOnF1, target=1.0)

var adapt = ProblemAdapter(problem, f1, f2)
var x0 = adapt.get()

// Joint energy gradient w.r.t. f1 and f2 (central FD)
var g = adapt.gradient()

if (!fdEnergyGradientCheck(adapt, 9, x0, g)) {
  Error("TstMltFldGrd", "Joint energy gradient FD check failed on f2").throw()
}

if (!fdEnergyGradientCheck(adapt, 0, x0, g)) {
  Error("TstMltFldGrd", "Joint energy gradient FD check failed on f1").throw()
}

// Edge constraint on f1 only: zero rows in f2 block, nonzero in f1 block
adapt.set(x0)
var cg = adapt.constraintGradient()

if (abs(cg[0][9, 0]) >= GradZeroTol) {
  Error("TstMltFldGrd", "Constraint gradient should be zero in f2 block").throw()
}

if (abs(cg[0][0, 0]) <= GradNonzeroTol) {
  Error("TstMltFldGrd", "Constraint gradient should be nonzero in f1 block").throw()
}

adapt.set(x0)
