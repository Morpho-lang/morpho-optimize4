// ProblemAdapter test: grade-0 vertex constraints and grade-1 edge constraints

import optimize4
import "../../examples/multigrade.morpho" for MultigradeExample
import "gradienthelpers.morpho" for fdLocalConstraintGradientCheck

var example = MultigradeExample()
var adapt = example.build()

var nvert = example.mesh.count(0)
var nedge = example.mesh.count(1)
var nmesh = adapt.count(example.mesh)

print nvert
// expect: 12

print nedge
// expect: 11

print adapt.countInequalityConstraints()
// expect: 1

print adapt.countEqualityConstraints()
// expect: 1

print adapt.countConstraints()
// expect: 2

var cvals = adapt.constraintValue()
print cvals.count()
// expect: 2

// Equalities (grade 1) first, then inequalities (grade 0)
print cvals[0].count()
// expect: 11

print cvals[1].count()
// expect: 12

var x0 = adapt.get()
var cg = adapt.constraintGradient()

// Grade 1: field gradient of edge-0 constraint w.r.t. first field DOF
print fdLocalConstraintGradientCheck(adapt, 0, nmesh, 0, x0, cg)
// expect: true

// Grade 0: mesh gradient of vertex-1 inequality w.r.t. y (vertex 0 lies on y=0)
var vert = 1
var yDof = 3*vert + 1
print fdLocalConstraintGradientCheck(adapt, 1, yDof, vert, x0, cg)
// expect: true

adapt.set(x0)
