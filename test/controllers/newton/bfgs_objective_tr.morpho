// BFGS with objective-based trust region on a poorly scaled quadratic

import optimize4
import "../../examples/quadratic.morpho"

var example = QuadraticExample()
var adapt = example.build()

var control = TrustRegionBFGSController(adapt, trustregion=ObjectiveTrustRegionController)
control.gradtol = 1e-8
control.optimize(100)

print example.check() < 1e-6
// expect: true

print control.hasConverged()
// expect: true
