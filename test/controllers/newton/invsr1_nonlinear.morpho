// InvSR1 on the nonlinear 2D saddle (from saddlepoint_driver_nonlinear_inv.morpho)

import optimize4
import "../../examples/saddle.morpho"

var problem = NonlinearSaddle2D()
var fadapt = problem.build()
var hessf = problem.hess()

var opt = InvSR1Controller(fadapt, maximize=[0])
opt.gradtol = 1e-5
opt.optimize(100)

var sol = fadapt.get()
print sol.norm() < 1e-6
// expect: true

print opt.gradient().norm() < 1e-5
// expect: true

var Msol = hessf(sol[0], sol[1]).inverse()
print (opt.hessian() - Msol).norm() < 1e-4
// expect: true
