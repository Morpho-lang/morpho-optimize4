// SR1 on a simple 2D saddle: f(x,y) = -x^2 + y^2 + c*x*y (minimum in y, maximum in x)
// Adapted from Research/SaddlePoint/saddlepoint_driver.morpho

import optimize4

var c = 0.25

fn f(x, y) {
  return -x^2 + y^2 + c*x*y
}

var fadapt = FunctionAdapter(f, start=Matrix([1, 1.5]))
var opt = SR1Controller(fadapt, maximize=[0])
opt.gradtol = 1e-5
opt.optimize(100)

var x = fadapt.get()
print x.norm() < 1e-10
// expect: true

print opt.gradient().norm() < 1e-10
// expect: true
