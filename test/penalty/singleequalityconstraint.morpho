// Single equality constraint (Nocedal & Wright 12.1) solved with penalty

import optimize4
import "../examples/singleequalityconstraint.morpho" for ConstrainedFunctionExample

var example = ConstrainedFunctionExample()
var adapt = example.build()
adapt.set(Matrix([0.2, -1]))

var control = PenaltyController(adapt)
control.optimize(100)

print adapt.get()
print example.check()
