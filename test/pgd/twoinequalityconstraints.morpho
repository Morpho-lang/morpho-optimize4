// Two inequality constraints (Nocedal & Wright 12.3) — PGD smoke test
// [CI:Smoke]  // PGD may stall linesearch from the default start; use a feasible interior point

import optimize4
import "../examples/twoinequalityconstraints.morpho" for ConstrainedFunctionExample

var example = ConstrainedFunctionExample()
var adapt = example.build()
adapt.set(Matrix([2.2, -0.5]))

var control = ProjectedGradientDescentController(adapt, mu=100)
control.optimize(100)

print adapt.get()
print example.check()
