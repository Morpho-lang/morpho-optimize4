// SR1 on a 4D block-structured saddle (from saddlepoint_driver_multi.morpho)

import optimize4
import "../examples/saddle.morpho"

var problem = BlockSaddle4D()
var fadapt = problem.build()
var hessf = problem.hess()

var opt = SR1Controller(fadapt, maximize=[0, 1])
opt.gradtol = 1e-5
opt.optimize(100)

var x = fadapt.get()
print x.norm() < 1e-12
// expect: true

print opt.gradient().norm() < 1e-12
// expect: true

var Happrox = opt.hessian()
var Hexact = hessf(0, 0, 0, 0)
print (Happrox - Hexact).norm() < 1e-10
// expect: true
