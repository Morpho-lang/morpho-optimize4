// Grad merit Phi = 1/2|grad f|^2 vs objective merit f.

import optimize4

fn f(x, y) { return x^2 + y^2 }
var adapt = FunctionAdapter(f, start=Matrix([1, 2]))
var opt = SR1Controller(adapt)

opt.start()
opt.begin()

var g = opt.gradient()
print abs(opt._gradMerit() - 0.5*g.inner(g)) < 1e-30
// expect: true

print abs(opt._objectiveMerit() - opt.value()) < 1e-30
// expect: true

print opt._usesGradMerit() == false
// expect: true

var sadd = TRSR1Controller(adapt, maximize=[0])
sadd.start()
print sadd._usesGradMerit() == true
// expect: true

var block = LSR1Controller(adapt, maximize=[0], gradmerit=false)
block.start()
print block._usesGradMerit() == false
// expect: true

print abs(sadd._hostTrustMerit() - sadd._gradMerit()) < 1e-30
// expect: true
