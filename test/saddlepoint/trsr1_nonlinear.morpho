// TRSR1 on the nonlinear 2D saddle

import optimize4
import "../examples/saddle.morpho"

var problem = NonlinearSaddle2D()
var fadapt = problem.build()

var opt = TRSR1Controller(fadapt, maximize=[0])
opt.gradtol = 1e-5
opt.optimize(100)

var x = fadapt.get()
print x.norm() < 1e-6
// expect: true

print opt.gradient().norm() < 1e-5
// expect: true
