// 1D objective TR along L-BFGS direction on a quadratic.

import optimize4
import "../examples/quadratic.morpho"

var example = QuadraticExample()
var adapt = example.build()

var control = TrustRegionLBFGSController(adapt, quiet=true, verbosity="silent",
    trustregion=ObjectiveTrustRegionController)
control.gradtol = 1e-8
control.optimize(100)

print example.check() < 1e-6
// expect: true

print control.hasConverged()
// expect: true
